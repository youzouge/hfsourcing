{
  "name": "hfsourcing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "cross-env \"NODE_OPTIONS=--dns-result-order=ipv4first --no-deprecation\" next dev --webpack",
    "devsafe": "rm -rf .next && cross-env \"NODE_OPTIONS=--dns-result-order=ipv4first --no-deprecation\" next dev --webpack",
    "build": "cross-env \"NODE_OPTIONS=--dns-result-order=ipv4first --no-deprecation\" next build",
    "start": "cross-env \"NODE_OPTIONS=--dns-result-order=ipv4first --no-deprecation\" next start",
    "lint": "eslint",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "graphql": "16.13.2",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "payload": "3.84.1",
    "pg-connection-string": "^2.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.73.1",
    "server-only": "^0.0.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": "20.x || 22.x",
    "pnpm": "^9 || ^10"
  }
}
