# === Required ===
# Strong secret (32+ random bytes). Never commit the real .env.
#   openssl rand -base64 32
PAYLOAD_SECRET=replace-with-openssl-rand-base64-32

# Supabase: Dashboard → Project Settings → Database → Connection string (URI, port 5432)
# If IPv6 issues on your network, try the "Session" pooler host from Supabase docs.
DATABASE_URI=postgres://USER:PASSWORD@db.xxxxx.supabase.co:5432/postgres

# Canonical site URL (no trailing slash). Local:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Vercel example:
# NEXT_PUBLIC_SERVER_URL=https://your-project.vercel.app

# Allowed browser origins for the API (comma-separated). Local + prod:
# PAYLOAD_PUBLIC_CORS_URLS=http://localhost:3000,https://your-project.vercel.app
PAYLOAD_PUBLIC_CORS_URLS=http://localhost:3000

# === Optional (Payload serverURL fallback; usually same as NEXT_PUBLIC_SERVER_URL) ===
# PAYLOAD_SERVER_URL=http://localhost:3000

# If you still see ENETUNREACH to an IPv6 address on Vercel, NODE_OPTIONS in package.json + vercel.json
# should handle it. Optional:
# DATABASE_IPV4_FIRST=1

# === DB adapter ===
# First deploy to an empty DB: set true, deploy once, then set false and use migrations
PAYLOAD_DB_PUSH=true

# DATABASE_SSL=true|false — force enable/disable TLS (default: on for known cloud hosts)
# DATABASE_SSL=false
# Stricter cert chain: only if you set true, TLS will verify the full chain (fails on some networks).
# Default (unset / false) matches getDatabasePoolOptions: URI sslmode params are ignored; TLS is via Pool.
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# === Vercel (set in dashboard; do not put secrets in repo) ===
# Required on Vercel: PAYLOAD_SECRET, DATABASE_URI, NEXT_PUBLIC_SERVER_URL, PAYLOAD_PUBLIC_CORS_URLS, PAYLOAD_DB_PUSH (true until schema exists)
# VERCEL_URL is set automatically. NEXT_PUBLIC_SERVER_URL should be your production URL.
